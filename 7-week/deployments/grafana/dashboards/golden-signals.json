    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Absolute host memory capacity: used, available, and total. Complements memory percentage with real-size context.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
